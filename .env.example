# API Keys
OPENAI_API_KEY=your_openai_api_key_here
#ANTHROPIC_API_KEY=your_anthropic_api_key_here
#JETSTREAM2_API_KEY=your_jetstream2_api_key_here  # Jetstream2 (ACCESS) API key
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here # Semantic Scholar API key (OPTIONAL for PaperQA)

# Database Configuration
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=idea_db
POSTGRES_USER=idea_user
POSTGRES_PASSWORD=changethis_secure_password

# Application Configuration
SECRET_KEY=changethis_secret_key_in_production
FIRST_SUPERUSER=admin@idea.com
FIRST_SUPERUSER_PASSWORD=changethis_secure_password

# Local Development
LOCAL_DEV=1

# CORS Configuration
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8001,http://127.0.0.1:8001,http://localhost
API_HOST=http://localhost

# HPC Cluster Configuration (optional)
# Set HPC_ENABLED=true and fill in the values below to enable HPC cluster execution.
# Set HPC_ENABLED=false (or leave unset) to disable without removing the other settings.
HPC_ENABLED=false
# SSH connection
#HPC_HOST=koa.its.hawaii.edu
#HPC_USER=your_hpc_username
#HPC_SSH_KEY_PATH=/app/.ssh/idea_hpc_key   # path inside container after .ssh/ dir is mounted
#HPC_SSH_PORT=22
# SLURM job defaults
#HPC_SCRATCH_DIR=/scratch/uhslc/idea_jobs
#HPC_DEFAULT_PARTITION=shared
#HPC_DEFAULT_ACCOUNT=                 # SLURM billing account / allocation name
#HPC_DEFAULT_WALLTIME=01:00:00
#HPC_DEFAULT_MEMORY=8G
# Software environment on the cluster
#HPC_CONDA_ENV=                       # conda environment to activate (e.g. idea-env)
#HPC_MODULES=                         # space-separated modules to load (e.g. "python/3.11 netcdf4/4.9")
# Safety
#HPC_MAX_JOBS_PER_USER=5


# LiteLLM Proxy
LITELLM_MASTER_KEY=changethis_litellm_master_key   # Admin secret for the LiteLLM proxy UI/API
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here