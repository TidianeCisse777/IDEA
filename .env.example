# Required values.
OPENAI_API_KEY=REPLACE_WITH_THE_OPENAI_KEY
ECOTAXA_USERNAME=REPLACE_WITH_THE_ECOTAXA_USERNAME
ECOTAXA_PASSWORD=REPLACE_WITH_THE_ECOTAXA_PASSWORD

# Generated by ./start.sh if empty.
MCP_AUTH_TOKEN=

# Optional overrides.
POSTGRES_PASSWORD=copepod_dev
LLM_MODEL=gpt-5.4-mini
LLM_MAX_OUTPUT_TOKENS=16000
MAX_CONTEXT_TOKENS=40000
MAX_TOOL_RESULT_CHARS=8000

# Public URL used in generated graph/download links.
# Keep the default for local Docker.
SERVE_BASE_URL=http://localhost:8000

# Open WebUI talks to the agent through the Docker network by default.
OPENWEBUI_AGENT_BASE_URL=http://copepod-agent:8000/v1

# Read-only SQL workspace (SQLAlchemy URL). Used by list_sql_tables, preview_sql_table, copy_sql_query_to_workspace.
# Paths must be absolute. Inside the agent container, the repo is mounted at /app.
# Examples:
#   sqlite:////app/data/sql_workspace_demo/ocean_observations.sqlite  (demo DB shipped with the repo)
#   postgresql+psycopg://user:password@host:5432/dbname
#   mysql+pymysql://user:password@host:3306/dbname
DATABASE_URL=
