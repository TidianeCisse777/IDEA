# API Keys
OPENAI_API_KEY=your_openai_api_key_here
#ANTHROPIC_API_KEY=your_anthropic_api_key_here
#JETSTREAM2_API_KEY=your_jetstream2_api_key_here  # Jetstream2 (ACCESS) API key
#GEMINI_API_KEY=your_gemini_api_key_here          # Google AI Studio — free tier (gemini-2.0-flash)
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here # Semantic Scholar API key (OPTIONAL for PaperQA)

# Database Configuration
DATABASE_URL=sqlite:////absolute/path/to/source.sqlite
# Supported SQL workspace examples:
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
# DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname
# MariaDB works through the MySQL protocol:
# DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname
# Optional row cap for SQL copies:
# SQL_WORKSPACE_MAX_COPY_ROWS=100000
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=idea_db
POSTGRES_USER=idea_user
POSTGRES_PASSWORD=changethis_secure_password

# Application Configuration
SECRET_KEY=changethis_secret_key_in_production
FIRST_SUPERUSER=admin@idea.com
FIRST_SUPERUSER_PASSWORD=changethis_secure_password

# Langfuse Observability (optional — LLM + RAG + tool traces)
# Keys are in Langfuse UI → Settings → API Keys
# In Docker: LANGFUSE_HOST=http://langfuse:3000 (set automatically via docker-compose)
# In local dev shell: LANGFUSE_HOST=http://localhost:3001
#LANGFUSE_PUBLIC_KEY=pk-lf-...
#LANGFUSE_SECRET_KEY=sk-lf-...
#LANGFUSE_HOST=http://localhost:3001
#LANGFUSE_SALT=changethis_random_salt  # used by the Langfuse Docker service

# Local Development
LOCAL_DEV=1

# LLM capabilities
# Désactive le function calling natif — utilise le parsing manuel des tool calls
LLM_SUPPORTS_FUNCTIONS=false
LLM_RAG_TEMPERATURE=0.3

# Public base URL used in tool outputs and download links.
# Set to your LAN IP or DNS name when colleagues access the WebUI.
# Example: SERVE_BASE_URL=http://192.168.1.25:8000
SERVE_ACCESS_MODE=local

# CORS Configuration
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8001,http://127.0.0.1:8001,http://localhost
API_HOST=http://localhost
