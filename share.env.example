# Copy this file to `.env` before running `./share_start.sh`.
# The launcher reads the project `.env` only and ignores your shell environment.

# LLM / OpenRouter
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=replace-me
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/openai/gpt-5.4-mini
LLM_REASONING_EFFORT=
LLM_CONTEXT_WINDOW=400000
LLM_MAX_COMPLETION_TOKENS=4096
LLM_MAX_OUTPUT=4096
LLM_TEMPERATURE=0.3
LLM_REPETITION_PENALTY=1.1
LLM_SUPPORTS_FUNCTIONS=false

# Database
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=idea_db
POSTGRES_USER=idea_user
POSTGRES_PASSWORD=idea_password_changethis

# Application
SECRET_KEY=replace-me
FIRST_SUPERUSER=admin@idea.com
FIRST_SUPERUSER_PASSWORD=replace-me

# Langfuse
LANGFUSE_PUBLIC_KEY=replace-me
LANGFUSE_SECRET_KEY=replace-me
LANGFUSE_SALT=replace-me
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_HOST_LOCAL=http://localhost:3001

# Optional host overrides for a local shareable stack
IDEA_WEB_HOST_PORT=8002
IDEA_DB_HOST_PORT=5433
IDEA_REDIS_HOST_PORT=6380
IDEA_FRONTEND_HOST_PORT=8000
IDEA_NGINX_HOST_PORT=80
LANGFUSE_HOST_PORT=3001
