# Copy this file to .env.mcp before launching docker-compose.mcp.yml.

# Required. Use a long random value.
MCP_AUTH_TOKEN=REPLACE_WITH_A_LONG_RANDOM_TOKEN

# EcoTaxa credentials. EcoTaxa is normally configured with username/password.
ECOTAXA_USERNAME=REPLACE_WITH_THE_ECOTAXA_USERNAME
ECOTAXA_PASSWORD=REPLACE_WITH_THE_ECOTAXA_PASSWORD

# Optional sync controls.
ECOTAXA_NIGHTLY_SYNC=true
ECOTAXA_SYNC_HOUR=3
