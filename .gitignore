# docs/ holds two things:
#   - Tracked, user-facing documentation in the whitelisted subfolders below.
#   - Internal working notes (test maps, scratch) that stay local only.
# Default: ignore everything under docs/, then re-include what should ship.
/docs/*
!/docs/.gitkeep
!/docs/README.md
!/docs/biodiversity_graph_test_plan.md
